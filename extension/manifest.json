{
  "manifest_version": 3,
  "name": "StudioBase",
  "version": "0.1.0",
  "description": "Capture workflows. Generate SOPs, demos, and videos automatically.",
  "key": "",
  "permissions": [
    "tabs",
    "storage",
    "identity",
    "activeTab",
    "scripting",
    "desktopCapture",
    "offscreen"
  ],
  "host_permissions": ["https://www.googleapis.com/*", "<all_urls>"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "http://localhost:3000/*",
      "https://studio.studiobase.app/*",
      "https://studiobase-umber.vercel.app/*"
    ]
  },
  "oauth2": {
    "client_id": "813435932187-l9vpdot4lsa51o4qa617o83111jgirot.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  }
}
