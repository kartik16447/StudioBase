{
  "manifest_version": 3,
  "name": "StudioBase",
  "version": "1.0.0",
  "description": "Record your screen, auto-generate step-by-step SOPs, interactive demos, and cinematic videos — powered by AI.",
  "homepage_url": "https://studiobase.app",
  "permissions": [
    "tabs",
    "storage",
    "identity",
    "activeTab",
    "scripting",
    "desktopCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://studio.studiobase.app/*"
    ]
  },
  "oauth2": {
    "client_id": "813435932187-oktc8br8kq98luccqgmsdnhju3h80lht.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  }
}