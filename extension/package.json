{
  "name": "screenvault",
  "version": "1.0.0",
  "scripts": {
    "build": "node build.mjs",
    "build:prod": "node build.mjs --prod",
    "watch": "node build.mjs --watch",
    "package": "rm -rf dist && node build.mjs --prod && cd dist && zip -r ../studiobase-extension.zip .",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "fix-webm-duration": "^1.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  }
}
